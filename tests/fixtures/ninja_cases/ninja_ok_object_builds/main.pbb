|{ cwd, pb, ... }|
let
    cp_rule = pb.rule (
        |{ input, output }| {
            command = [ "cp", input, output ];
        }
    );
in
{
    first = pb.build {
        rule = cp_rule;
        input = cwd / "a.in";
        output = cwd / "a.out";
    };
    second = pb.build {
        rule = cp_rule;
        input = cwd / "b.in";
        output = cwd / "b.out";
    };
}
