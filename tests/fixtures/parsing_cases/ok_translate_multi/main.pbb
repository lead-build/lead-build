|{ cwd, pb, ... }|
let
    do_rebase = |path| pb.translate {
        input = path;
        from = [
            "${cwd}/from_a",
            "${cwd}/from_b",
        ];
        to = "${cwd}/to";
    };
in
((do_rebase "${cwd}/from_a/dir/file.txt") == "${cwd}/to/dir/file.txt") &&
((do_rebase "${cwd}/from_b/dir/file.txt") == "${cwd}/to/dir/file.txt")